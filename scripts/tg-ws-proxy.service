[Unit]
Description=Telegram WebSocket Bridge Proxy
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/tg-ws-proxy
ExecStart=/usr/bin/python3 -m proxy.tg_ws_proxy --port 8080 --host 0.0.0.0
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
