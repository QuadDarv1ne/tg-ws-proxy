{
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "socks_port": 1080,
    "auto_port": false,
    "max_connections": 500,
    "connection_timeout": 30.0
  },
  "websocket": {
    "pool_size": 4,
    "pool_max_size": 8,
    "pool_max_age": 120.0,
    "enable_compression": false,
    "ping_interval": 30.0,
    "ping_timeout": 10.0,
    "reconnect_delay": 5.0,
    "max_reconnect_attempts": 10
  },
  "dns": {
    "enable_cache": true,
    "cache_ttl": 300.0,
    "aggressive_ttl": true,
    "use_async_dns": true,
    "timeout": 5.0
  },
  "security": {
    "auth_required": false,
    "auth_username": "",
    "auth_password": "",
    "ip_whitelist": [],
    "ip_blacklist": [],
    "rate_limit_enabled": false,
    "rate_limit_requests": 100,
    "rate_limit_window": 60.0,
    "enable_encryption": false,
    "encryption_key": ""
  },
  "performance": {
    "enable_connection_pooling": true,
    "enable_auto_dc_selection": true,
    "enable_dns_cache": true,
    "tcp_nodelay": true,
    "recv_buffer_size": 65536,
    "send_buffer_size": 65536,
    "enable_profiling": false,
    "profiling_interval": 60.0
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "file": "",
    "max_size_mb": 10,
    "backup_count": 3,
    "enable_audit": false,
    "audit_file": "audit.log"
  },
  "monitoring": {
    "enable_metrics": true,
    "metrics_port": 9090,
    "enable_prometheus": true,
    "prometheus_path": "/metrics",
    "enable_alerts": true,
    "alert_dc_latency_warning": 150.0,
    "alert_dc_latency_critical": 200.0,
    "alert_cooldown": 120.0
  },
  "dc_override": {
    "1": "149.154.175.50",
    "2": "149.154.167.220",
    "3": "149.154.175.100",
    "4": "149.154.167.91",
    "5": "149.154.171.5"
  }
}
